---
import config from '../data/config.js';

export function getStaticPaths() {
  return [
    { params: { theme: 'glassmorphism' } },
    { params: { theme: 'gradient-glow' } },
    { params: { theme: 'editorial' } },
    { params: { theme: 'hybrid' } },
  ];
}

const { theme } = Astro.params;
const { profile, social, experience, education, projects, skills, awards } = config;

const themeStyles = {
  'glassmorphism': '/themes/glassmorphism/theme.css',
  'gradient-glow': '/themes/gradient-glow/theme.css',
  'editorial': '/themes/editorial/theme.css',
  'hybrid': '/themes/hybrid/theme.css',
};

const themeNames = {
  'glassmorphism': 'Glassmorphism',
  'gradient-glow': 'Gradient & Glow',
  'editorial': 'Editorial',
  'hybrid': 'Hybrid',
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{profile.name} - {themeNames[theme]} Theme</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href={themeStyles[theme]} rel="stylesheet" />
  </head>
  <body>
    <main>
      {theme === 'glassmorphism' && (
        <>
          <section class="hero-section">
            <div>
              <div class="hero-avatar">
                <div class="hero-avatar-inner">{profile.name.charAt(0)}</div>
              </div>
              <h1 class="hero-name">{profile.name}</h1>
              <p class="hero-title">{profile.title}</p>
              <p class="hero-bio">{profile.bio}</p>
              <div class="hero-location">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span>{profile.location}</span>
              </div>
              <div class="social-links">
                {social.github && <a href={`https://github.com/${social.github}`} class="social-link" target="_blank" rel="noopener"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg></a>}
                {social.linkedin && <a href={`https://linkedin.com/in/${social.linkedin}`} class="social-link" target="_blank" rel="noopener"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>}
              </div>
            </div>
          </section>
        </>
      )}
      
      {theme === 'gradient-glow' && (
        <>
          <section class="hero-section">
            <div style="position: relative; z-index: 1;">
              <div class="hero-avatar">
                <div class="hero-avatar-inner">{profile.name.charAt(0)}</div>
              </div>
              <h1 class="hero-name">{profile.name}</h1>
              <p class="hero-title">{profile.title}</p>
              <p class="hero-bio">{profile.bio}</p>
              <div class="hero-location">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span>{profile.location}</span>
              </div>
              <div class="social-links">
                {social.github && <a href={`https://github.com/${social.github}`} class="social-link" target="_blank" rel="noopener"><svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg></a>}
              </div>
            </div>
          </section>
        </>
      )}
      
      {theme === 'editorial' && (
        <>
          <section class="container-page">
            <div class="hero-section">
              <div class="hero-content">
                <p class="hero-label">Portfolio</p>
                <h1 class="hero-name"><span>{profile.name}</span></h1>
                <p class="hero-title">{profile.title}</p>
                <p class="hero-bio">{profile.bio}</p>
                <div class="hero-location">
                  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  <span>{profile.location}</span>
                </div>
                <div class="social-links">
                  {social.github && <a href={`https://github.com/${social.github}`} class="social-link" target="_blank" rel="noopener">GitHub</a>}
                  {social.linkedin && <a href={`https://linkedin.com/in/${social.linkedin}`} class="social-link" target="_blank" rel="noopener">LinkedIn</a>}
                </div>
              </div>
              <div class="hero-visual">
                <div class="hero-avatar">
                  <span class="hero-avatar-inner">{profile.name.charAt(0)}</span>
                </div>
                <div class="hero-decoration"></div>
              </div>
            </div>
          </section>
        </>
      )}
      
      {theme === 'hybrid' && (
        <>
          <section class="hero-section container-page">
            <div class="hero-top">
              <span class="hero-label">Portfolio</span>
              <div class="hero-avatar">
                <div class="hero-avatar-inner">{profile.name.charAt(0)}</div>
              </div>
            </div>
            <div class="hero-main">
              <h1 class="hero-name">{profile.name}</h1>
              <p class="hero-title">{profile.title}</p>
              <p class="hero-bio">{profile.bio}</p>
              <div class="hero-location">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span>{profile.location}</span>
              </div>
            </div>
            <div class="social-links">
              {social.github && <a href={`https://github.com/${social.github}`} class="social-link" target="_blank" rel="noopener"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg></a>}
            </div>
          </section>
        </>
      )}

      <div class="section-divider" style="margin: 40px 24px;"></div>

      {theme === 'glassmorphism' && (
        <section class="container-page">
          <h2 class="section-title">Experience</h2>
          <div class="glass-card">
            {experience.map((item, i) => (
              <div class="timeline-item" style={`animation-delay: ${i * 0.1}s`}>
                <span class="timeline-period">{item.period}</span>
                <h3 class="timeline-position">{item.position}</h3>
                <p class="timeline-company">{item.company}</p>
                <p class="timeline-description">{item.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {theme === 'gradient-glow' && (
        <section class="container-page">
          <h2 class="section-title">Experience</h2>
          <div class="neon-card">
            <div class="timeline">
              {experience.map((item) => (
                <div class="timeline-item">
                  <span class="timeline-period">{item.period}</span>
                  <div class="timeline-content">
                    <h3>{item.position}</h3>
                    <p class="timeline-company">{item.company}</p>
                    <p class="timeline-description">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {theme === 'editorial' && (
        <section class="container-page">
          <div class="section-header">
            <h2 class="section-title">Experience</h2>
            <span class="section-number">01</span>
          </div>
          <div class="experience-grid">
            {experience.map((item) => (
              <div class="experience-item">
                <p class="experience-period">{item.period}</p>
                <h3 class="experience-position">{item.position}</h3>
                <p class="experience-company">{item.company}</p>
                <p class="experience-description">{item.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {theme === 'hybrid' && (
        <section class="container-page">
          <h2 class="section-title">Experience</h2>
          <div class="frosted-card">
            <div class="timeline">
              {experience.map((item) => (
                <div class="timeline-item">
                  <span class="timeline-period">{item.period}</span>
                  <div class="timeline-content">
                    <h3>{item.position}</h3>
                    <p class="timeline-company">{item.company}</p>
                    <p class="timeline-description">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <div class="section-divider" style="margin: 40px 24px;"></div>

      {theme === 'glassmorphism' && (
        <section class="container-page">
          <h2 class="section-title">Skills</h2>
          <div class="glass-card">
            <div class="skills-container">
              {skills.map((skill) => (
                <div class="skill-group">
                  <span class="skill-label">{skill.category}</span>
                  <div class="skill-tags">
                    {skill.items.map((item) => (
                      <span class="skill-tag">{item}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {theme === 'gradient-glow' && (
        <section class="container-page">
          <h2 class="section-title">Skills</h2>
          <div class="skills-container">
            {skills.map((skill) => (
              <div class="skill-group">
                <span class="skill-label">{skill.category}</span>
                <div class="skill-tags">
                  {skill.items.map((item) => (
                    <span class="skill-tag">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {theme === 'editorial' && (
        <section class="container-page">
          <div class="section-header">
            <h2 class="section-title">Skills</h2>
            <span class="section-number">04</span>
          </div>
          <div class="skills-container">
            {skills.map((skill) => (
              <div class="skill-group">
                <span class="skill-label">{skill.category}</span>
                <div class="skill-tags">
                  {skill.items.map((item) => (
                    <span class="skill-tag">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {theme === 'hybrid' && (
        <section class="container-page">
          <h2 class="section-title">Skills</h2>
          <div class="skills-container">
            {skills.map((skill) => (
              <div class="skill-group">
                <span class="skill-label">{skill.category}</span>
                <div class="skill-tags">
                  {skill.items.map((item) => (
                    <span class="skill-tag">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <div class="section-divider" style="margin: 40px 24px;"></div>

      {theme === 'glassmorphism' && (
        <section class="container-page">
          <h2 class="section-title">Featured Projects</h2>
          <div class="projects-grid">
            {projects.filter(p => p.featured).map((project) => (
              <article class="glass-card project-card">
                <div class="project-icon">
                  <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                </div>
                <h3 class="project-name">{project.name}</h3>
                <p class="project-description">{project.description}</p>
                <div class="project-tags">
                  {project.tags.map((tag) => (<span class="project-tag">{tag}</span>))}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      {theme === 'gradient-glow' && (
        <section class="container-page">
          <h2 class="section-title">Featured Projects</h2>
          <div class="projects-grid">
            {projects.filter(p => p.featured).map((project) => (
              <article class="neon-card project-card">
                <div class="project-icon">
                  <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                </div>
                <h3 class="project-name">{project.name}</h3>
                <p class="project-description">{project.description}</p>
                <div class="project-tags">
                  {project.tags.map((tag) => (<span class="project-tag">{tag}</span>))}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      {theme === 'editorial' && (
        <section class="container-page">
          <div class="section-header">
            <h2 class="section-title">Featured Projects</h2>
            <span class="section-number">03</span>
          </div>
          <div class="projects-grid">
            {projects.filter(p => p.featured).map((project) => (
              <article class="project-card">
                <h3 class="project-name">{project.name}</h3>
                <p class="project-description">{project.description}</p>
                <div class="project-tags">
                  {project.tags.map((tag) => (<span class="project-tag">{tag}</span>))}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      {theme === 'hybrid' && (
        <section class="container-page">
          <h2 class="section-title">Featured Projects</h2>
          <div class="projects-grid">
            {projects.filter(p => p.featured).map((project) => (
              <article class="frosted-card project-card">
                <div class="project-icon">
                  <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg>
                </div>
                <h3 class="project-name">{project.name}</h3>
                <p class="project-description">{project.description}</p>
                <div class="project-tags">
                  {project.tags.map((tag) => (<span class="project-tag">{tag}</span>))}
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      <footer class={theme === 'editorial' ? 'footer container-page' : 'footer'}>
        <p>&copy; {new Date().getFullYear()} {profile.name}. All rights reserved.</p>
        <p>Built with <a href="https://astro.build" target="_blank">Astro</a></p>
      </footer>
    </main>
  </body>
</html>
