---
const { awards } = Astro.props;
---

<section class="py-16 section-divider">
  <h2 class="section-title">荣誉奖项</h2>
  
  <div class="grid gap-4">
    {awards.map((award) => (
      <div class="card flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-yellow-400 to-orange-500 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
        </div>
        
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            <h3 class="font-semibold text-primary">{award.title}</h3>
            <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">{award.year}</span>
          </div>
          <p class="text-sm text-secondary">{award.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
