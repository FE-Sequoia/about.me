---
const { projects } = Astro.props;
const featuredProjects = projects.filter(p => p.featured);
const otherProjects = projects.filter(p => !p.featured);
---

<section class="py-16 section-divider">
  <h2 class="section-title">精选项目</h2>
  
  <div class="grid gap-6 md:grid-cols-2">
    {featuredProjects.map((project) => (
      <article class="card group">
        <div class="flex items-start justify-between mb-4">
          <div class="p-3 rounded-xl bg-accent-light">
            <svg class="w-6 h-6 accent-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
          </div>
          
          {project.url && (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:bg-secondary transition-colors link-icon">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
        
        <h3 class="text-xl font-semibold text-primary mb-2 group-hover:accent-primary transition-colors">
          {project.name}
        </h3>
        
        <p class="text-secondary mb-4 leading-relaxed">
          {project.description}
        </p>
        
        <div class="flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
  
  {otherProjects.length > 0 && (
    <div class="mt-8 grid gap-4">
      {otherProjects.map((project) => (
        <article class="flex items-center gap-4 p-4 rounded-xl border border-default hover:bg-secondary transition-colors">
          <div class="p-2 rounded-lg bg-secondary">
            <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
          </div>
          
          <div class="flex-1 min-w-0">
            <h3 class="font-medium text-primary truncate">
              {project.name}
            </h3>
            <p class="text-sm text-secondary truncate">
              {project.description}
            </p>
          </div>
          
          <div class="hidden sm:flex gap-2">
            {project.tags.slice(0, 2).map((tag) => (
              <span class="tag text-xs">{tag}</span>
            ))}
          </div>
          
          {project.url && (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg hover:bg-secondary transition-colors link-icon">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </article>
      ))}
    </div>
  )}
</section>
